local function applyESP(t) if not t or not t.Parent then return end local hp,mhp=t:GetAttribute("Health") or 0,t:GetAttribute("MaxHealth") or(t:GetAttribute("Health") or 0) local r=mhp>0 and math.clamp(hp/mhp,0,1) or 1 local bc=Color3.fromRGB(math.floor((1-r)*255),math.floor(r*200),0) local ad=t.PrimaryPart or t:FindFirstChildWhichIsA("BasePart",true) if not ad then return end local bb=espHL[t] if not bb or not bb.Parent then bb=Instance.new("BillboardGui") bb.Name,bb.Size,bb.StudsOffset,bb.AlwaysOnTop,bb.Adornee,bb.Parent="ESP",UDim2.new(0,80,0,36),Vector3.new(0,6,0),true,ad,ad local lbl=Instance.new("TextLabel",bb) lbl.Name,lbl.Size,lbl.BackgroundTransparency,lbl.TextColor3,lbl.Font,lbl.TextSize="HP",UDim2.new(1,0,0,16),1,Color3.new(1,1,1),Enum.Font.GothamBold,13 local bg=Instance.new("Frame",bb) bg.Name,bg.Size,bg.Position,bg.BackgroundColor3,bg.BorderSizePixel="BG",UDim2.new(1,0,0,8),UDim2.new(0,0,0,18),Color3.fromRGB(40,40,40),0 Instance.new("UICorner",bg).CornerRadius=UDim.new(0,3) local fl=Instance.new("Frame",bg) fl.Name,fl.Size,fl.BackgroundColor3,fl.BorderSizePixel="Fill",UDim2.new(1,0,1,0),bc,0 Instance.new("UICorner",fl).CornerRadius=UDim.new(0,3) espHL[t]=bb else bb.Adornee=ad end local lbl,bf=bb:FindFirstChild("HP"),bb.BG and bb.BG:FindFirstChild("Fill") if lbl then lbl.Text=math.floor(hp).."/"..math.floor(mhp) end if bf then bf.Size,bf.BackgroundColor3=UDim2.new(r,0,1,0),bc end end
local function clearESP() for _,h in pairs(espHL) do if h then h:Destroy() end end espHL={} end
task.spawn(function() while true do task.wait(.5) if not ESP_ON then continue end local f=workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Foliage") if not f then continue end for t,h in pairs(espHL) do if not t or not t.Parent or(t:GetAttribute("Health") or 0)<=0 then if h then h:Destroy() end espHL[t]=nil end end for _,t in pairs(f:GetChildren()) do if isRes(t) and isAlive(t) and(not ESP_SEL or ESP_SEL=="All Trees" or t.Name==ESP_SEL) then applyESP(t) end end end end)

