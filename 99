local function scanItems() local s,r={},{} local f=workspace:FindFirstChild("Items") if f then for _,c in pairs(f:GetChildren()) do if not s[c.Name] then s[c.Name]=1 table.insert(r,c.Name) end end end table.sort(r) return r end
local function scanLocs() local l,mf={},RS:FindFirstChild("Map") if mf then for _,f in pairs(mf:GetChildren()) do local x,y,z=f:GetAttribute("X"),f:GetAttribute("Y"),f:GetAttribute("Z") local pa=f:GetAttribute("Position") if pa and typeof(pa)=="Vector3" then x,y,z=pa.X,pa.Y,pa.Z end if x and z then table.insert(l,{Name=f.Name,Pos=Vector3.new(x,y or 0,z)}) end end end table.sort(l,function(a,b) return a.Name<b.Name end) return l end
local function scanGrind() local s,r,f={},{},workspace:FindFirstChild("Items") if f then for _,c in pairs(f:GetChildren()) do local sc,cg,ig=c:GetAttribute("Scrappable"),false,false pcall(function() cg=c:HasTag("CanBeGrinded") ig=c:HasTag("Gem") end) if(sc or cg or ig) and not s[c.Name] then s[c.Name]=1 table.insert(r,c.Name) end end end table.sort(r) return r end
local function scanTrees() local n,s,f={},{},workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Foliage") if f then for _,o in pairs(f:GetChildren()) do if isRes(o) and not s[o.Name] then s[o.Name]=1 table.insert(n,o.Name) end end end table.sort(n) table.insert(n,1,"All Trees") return n end
local function scanByList(ml) local r,s,f={},{},workspace:FindFirstChild("Items") if f then for _,c in pairs(f:GetChildren()) do for _,n in ipairs(ml) do if c.Name==n and not s[n] then s[n]=1 table.insert(r,n) end end end end table.sort(r) return r end
local function scanPlayers() local n={} for _,p in pairs(Players:GetPlayers()) do if p~=P then table.insert(n,p.Name) end end table.sort(n) return n end
local function scanLocNames() local l,n=scanLocs(),{} for _,loc in ipairs(l) do table.insert(n,loc.Name) end return n end

