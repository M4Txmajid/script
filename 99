	-- ══════════════════════════════════════════════════════════════════

	local QuestTab = Window:AddTab({ Title = "Quest", Icon = "star" })

	local questRunning = false
	local questGen     = 0

	QuestTab:AddParagraph({
		Title   = "Missing Kids Quest",
		Content = "Automatically collects all missing kids and returns them to the campfire.\nRequires an Old Sack in your inventory.",
	})

	local function runQuestLoop(gen)
		local completed = 0
		local total     = #QUEST_KIDS
		for _, kid in ipairs(QUEST_KIDS) do
			if not questRunning or questGen ~= gen then return end
			if kid.approachPos then tpTo(kid.approachPos) end
			task.wait(0.8)
			local npc = nil
			for _ = 1, 12 do
				npc = getLiveNPC(kid.npcName)
				if npc then break end
				task.wait(0.5)
			end
			if not npc then task.wait(1) continue end
			local npcPart = npc:FindFirstChild("HumanoidRootPart") or npc.PrimaryPart or npc:FindFirstChildWhichIsA("BasePart")
			if not npcPart then task.wait(1) continue end
			tpTo(npcPart.Position + Vector3.new(0, 25, 0))
			task.wait(0.5)
			if not questRunning or questGen ~= gen then return end
			local bag = getBag()
			if not bag then
				ShowNotif("Quest", "Old Sack not in Inventory!", "error")
				task.wait(1)
				continue
			end
			pcall(function() RequestBagStore:InvokeServer(bag, npc) end)
			task.wait(1)
			if not questRunning or questGen ~= gen then return end
			local campPos = findCampfirePos()
			if campPos then tpTo(campPos + Vector3.new(0, 6, 0)) end
			task.wait(1)
			if not questRunning or questGen ~= gen then return end
			pcall(function() RequestBagDrop:FireServer(bag, npc, true) end)
			task.wait(1)
			if not questRunning or questGen ~= gen then return end
			completed += 1
		end
		questRunning = false
		ShowNotif("Quest", "Done! " .. completed .. "/" .. total .. " kids returned.", "success")
	end

	QuestTab:AddButton({
		Title       = "Start Quest",
		Description = "Auto-completes the Missing Kids quest",
		Callback    = function()
			if questRunning then ShowNotif("Quest", "Quest is already running!", "warn") return end
			if not HRP or not HRP.Parent then ShowNotif("Quest", "Character not found.", "error") return end
			questRunning = true
			questGen     = questGen + 1
			buildQuestKids()
			local g = questGen
			ShowNotif("Quest", "Starting Missing Kids quest...", "info")
			task.spawn(function() runQuestLoop(g) end)
		end,
	})

