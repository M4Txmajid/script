-- Game Utility
local function gVS() hitCounter+=1 return hitCounter.."_"..math.abs(P.UserId) end
local function tPos(t) local p pcall(function() p=t.PrimaryPart and t.PrimaryPart.Position or t:IsA("BasePart") and t.Position or t:GetPivot().Position end) return p end
local function gDist(t) return HRP and HRP.Parent and tPos(t) and(HRP.Position-tPos(t)).Magnitude or math.huge end
local function isRes(o) return o:GetAttribute("Interaction")=="Resource" or o:GetAttribute("Resource") end
local function isAlive(t) return t and t.Parent and(t:GetAttribute("Health")or 0)>0 end
local function tpTo(p) if HRP and HRP.Parent then HRP.CFrame=CFrame.new(p) end end
local function tpHold(p,t) if not HRP or not HRP.Parent then return false end t=t or.3 for _=1,3 do HRP.CFrame=CFrame.new(p) task.wait(.05) end local s=tick() while tick()-s<t do if not HRP or not HRP.Parent then return false end HRP.CFrame=CFrame.new(p) task.wait(.03) end return true end
