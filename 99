local function startCoins() coinRun=true task.spawn(function() while coinRun do task.wait(.5) if not HRP then continue end for _,c in pairs(CS:GetTagged("Coins")) do if c and c.Parent and not c:GetAttribute("QueuedToTake") then local p=c:FindFirstChildWhichIsA("BasePart",true) if p then p.CFrame=HRP.CFrame end c:SetAttribute("QueuedToTake",true) if FCC then pcall(function() FCC.PickupCoins(c) end) end end end end end) end
