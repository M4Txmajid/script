-- Quest
local function kidPos(i) local mk=workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("MissingKids") if mk then local a=mk:GetAttribute(KID_ID[i]) if a and typeof(a)=="Vector3" then return a end end end
local function kidProg() local nb=workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Campground") and workspace.Map.Campground:FindFirstChild("NoticeBoard") return nb and nb:GetAttribute("KidProgress") or 1 end
local function kidFound(i) local nb=workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Campground") and workspace.Map.Campground:FindFirstChild("NoticeBoard") if nb then local tr=nb:FindFirstChild("MissingKidTracker") if tr then local f=tr:FindFirstChild(KID_ID[i]) if f and f:GetAttribute("Found") then return true end end end return false end
local function npcPos(n) if not n then return end local p=n:FindFirstChild("HumanoidRootPart") or n.PrimaryPart return p and p.Position end
local function findKid(i) local ch=workspace:FindFirstChild("Characters") if ch then local n=ch:FindFirstChild(KID_NPC[i]) if n then return n end end for _,n in pairs(CS:GetTagged("ChildNPC")) do if n:GetAttribute("KidId")==KID_ID[i] then return n end end local mk=workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("MissingKids") if mk then local n=mk:FindFirstChild(KID_NPC[i]) if n then return n end end end
local function loadKids() boost() local pr,ld,tl=kidProg(),0,{} for i=1,4 do if kidFound(i) or i>pr then elseif findKid(i) then ld+=1 else table.insert(tl,i) end end for _,i in ipairs(tl) do if not questRun then break end local p=kidPos(i) if not p then continue end stream(p) tpTo(Vector3.new(p.X,p.Y+3,p.Z)) task.wait(.2) if findKid(i) then ld+=1 continue end stream(Vector3.new(p.X,0,p.Z)) tpTo(Vector3.new(p.X,p.Y+1,p.Z)) task.wait(.3) if findKid(i) then ld+=1 continue end for _,o in ipairs({Vector3.zero,Vector3.new(15,0,0),Vector3.new(-15,0,0),Vector3.new(0,0,15),Vector3.new(0,0,-15)}) do if not questRun then break end tpTo(p+o+Vector3.new(0,3,0)) stream(p+o) task.wait(.1) if findKid(i) then ld+=1 break end end end return ld end
local function grabKid(n,b) if not n or not b or not HRP then return false end local p=npcPos(n) if not p then return false end tpHold(p,.4) for _=1,8 do p=npcPos(n) if p then HRP.CFrame=CFrame.new(p) end pcall(function() ReqBagStore:InvokeServer(b,n) end) task.wait(.15) if not npcPos(n) then return true end end return true end
local function dropKid(b,n,i) if not b or not n then return false end local cp=campPos() if not cp then return false end stream(cp) task.wait(.1) local dp=cp+Vector3.new(0,5,0) tpHold(dp,.5) for _=1,5 do if HRP then HRP.CFrame=CFrame.new(dp) end task.wait(.05) pcall(function() ReqBagDrop:FireServer(b,n,true) end) task.wait(.1) end local st=tick() while tick()-st<3 do if not questRun or not HRP then break end HRP.CFrame=CFrame.new(dp) if kidFound(i) then return true end pcall(function() ReqBagDrop:FireServer(b,n,true) end) task.wait(.2) end task.wait(.5) return kidFound(i) end
local function runQuest() if questRun or not HRP then return"Err" end local bg=getBag() if not bg then return"NoBag" end local cp=campPos() if not cp then return"NoCamp" end questRun=true loadKids() if not questRun then questRun=false return"Stop" end stream(cp) tpHold(cp+Vector3.new(0,5,0),.3) local dn,fl,sk=0,0,0 for i=1,4 do if not questRun then break end if kidFound(i) or i>kidProg() then sk+=1 continue end local n=findKid(i) if not n then fl+=1 continue end bg=getBag() if not bg then fl+=1 continue end grabKid(n,bg) if not questRun then break end bg=getBag() if not bg then fl+=1 continue end if dropKid(bg,n,i) or kidFound(i) then dn+=1 else fl+=1 end task.wait(.3) end tpHold(cp+Vector3.new(0,5,0),.3) questRun=false return dn,fl,sk end
local function stopQuest() questRun,autoQuest=false,false end
local function togAutoQuest() if autoQuest then autoQuest,questRun=false,false return false end autoQuest=true task.spawn(function() while autoQuest do if not questRun then runQuest() end while questRun and autoQuest do task.wait(.5) end if autoQuest then local all,pr=true,kidProg() for i=1,4 do if i<=pr and not kidFound(i) then all=false break end end task.wait(all and 10 or 3) end end end) return true end

