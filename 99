				if p then return p.Position end
			end
		end
		local map = workspace:FindFirstChild("Map")
		if map then
			for _, child in pairs(map:GetDescendants()) do
				if (child.Name == "MainFire" or child.Name == "Campfire") and child:IsA("Model") then
					local p = child.PrimaryPart or child:FindFirstChildWhichIsA("BasePart", true)
					if p then return p.Position end
				end
			end
		end
		return nil
	end

