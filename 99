local function campPos() local cg=workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Campground") if cg then for _,n in ipairs({"MainFire","Campfire"}) do local f=cg:FindFirstChild(n) if f then local p=f.PrimaryPart or f:FindFirstChildWhichIsA("BasePart",true) if p then return p.Position end end end end end
