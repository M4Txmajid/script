local EasterEggRE=RS.RemoteEvents:FindFirstChild("RequestGiveEasterEgg")
local autoEasterEgg=false

local function getNil(name,debugId)
	if not getnilinstances then return nil end
	local ok,result=pcall(function()
		for _,obj in getnilinstances() do
			if obj.Name==name and obj:GetDebugId()==debugId then
				return obj
			end
		end
	end)
	return ok and result or nil
end

local function doGiveEasterEgg()
	if not EasterEggRE then EasterEggRE=RS.RemoteEvents:FindFirstChild("RequestGiveEasterEgg") end
	if not EasterEggRE then Notif("Egg","Remote not found","error") return false end
	local zone=workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Landmarks") and workspace.Map.Landmarks:FindFirstChild("Easter Bunny House") and workspace.Map.Landmarks["Easter Bunny House"]:FindFirstChild("Functional") and workspace.Map.Landmarks["Easter Bunny House"].Functional:FindFirstChild("EasterEggZone")
	if not zone then Notif("Egg","EasterEggZone not found","error") return false end
	local frogEgg=getNil("Frog Egg","1_352217")
	if not frogEgg then Notif("Egg","Frog Egg nil not found","error") return false end
	local ok,res=pcall(function() return EasterEggRE:InvokeServer(frogEgg,zone) end)
	if ok and res and res.Success then return true end
	return false
end

local function scanEggs()
	local s,r={},{} local f=workspace:FindFirstChild("Items")
	if f then for _,c in pairs(f:GetChildren()) do if c.Name:lower():find("egg") and not s[c.Name] then s[c.Name]=1 table.insert(r,c.Name) end end end
	table.sort(r) return r
end
