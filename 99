local function loadKids() boost() local pr,ld,tl=kidProg(),0,{} for i=1,4 do if kidFound(i) or i>pr then elseif findKid(i) then ld+=1 else table.insert(tl,i) end end for _,i in ipairs(tl) do if not questRun then break end local p=kidPos(i) if not p then continue end stream(p) tpTo(Vector3.new(p.X,p.Y+3,p.Z)) task.wait(.2) if findKid(i) then ld+=1 continue end stream(Vector3.new(p.X,0,p.Z)) tpTo(Vector3.new(p.X,p.Y+1,p.Z)) task.wait(.3) if findKid(i) then ld+=1 continue end for _,o in ipairs({Vector3.zero,Vector3.new(15,0,0),Vector3.new(-15,0,0),Vector3.new(0,0,15),Vector3.new(0,0,-15)}) do if not questRun then break end tpTo(p+o+Vector3.new(0,3,0)) stream(p+o) task.wait(.1) if findKid(i) then ld+=1 break end end end return ld end
