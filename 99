local function firePrompt(pr) if not pr then return false end local od,ol,oe,oh=pr.MaxActivationDistance,pr.RequiresLineOfSight,pr.Enabled,pr.HoldDuration pr.MaxActivationDistance,pr.RequiresLineOfSight,pr.Enabled,pr.HoldDuration=9e9,false,true,0 local ok=false if fireproximityprompt then pcall(function() fireproximityprompt(pr,0) ok=true end) end task.defer(function() pcall(function() pr.MaxActivationDistance,pr.RequiresLineOfSight,pr.Enabled,pr.HoldDuration=od,ol,oe,oh end) end) return ok end
local function getChests() local c,f={},workspace:FindFirstChild("Items") if f then for _,ch in pairs(f:GetChildren()) do if ch.Name:lower():find("chest") then table.insert(c,ch) end end end return c end
local function bringToMe(i) if not HRP then return end local p=i.PrimaryPart or i:FindFirstChildWhichIsA("BasePart",true) if p then p.CFrame=HRP.CFrame*CFrame.new(math.random(-5,5),math.random(3,8),math.random(-5,5)) pcall(function() ReqDrag:FireServer(i) end) end end
local function openChests() if not HRP then return 0,0 end local f=workspace:FindFirstChild("Items") if not f then return 0,0 end local ex={} for _,c in pairs(f:GetChildren()) do ex[c]=1 end local ch,op=getChests(),0 for _,c in ipairs(ch) do for _,d in pairs(c:GetDescendants()) do if d:IsA("ProximityPrompt") then if firePrompt(d) then op+=1 end task.wait(.15) elseif d:IsA("ClickDetector") then if fireclickdetector then pcall(function() fireclickdetector(d) end) end op+=1 end end task.wait(.2) end local br,ab=0,{} for _=1,6 do task.wait(.5) if not HRP then break end for _,c in pairs(f:GetChildren()) do if not ex[c] and not ab[c] and not c.Name:lower():find("chest") then ab[c]=1 bringToMe(c) br+=1 end end end return op,br end
local function startAutoChest() autoChest=true task.spawn(function() while autoChest do task.wait(2) if not autoChest or not HRP then continue end local f=workspace:FindFirstChild("Items") if not f then continue end local bf={} for _,c in pairs(f:GetChildren()) do bf[c]=1 end local op=false for _,c in ipairs(getChests()) do for _,d in pairs(c:GetDescendants()) do if d:IsA("ProximityPrompt") and d.Enabled then firePrompt(d) op=true task.wait(.15) end end end if op then task.wait(1.5) for _,c in pairs(f:GetChildren()) do if not bf[c] and not c.Name:lower():find("chest") then bringToMe(c) task.wait(.05) end end end end end) end

