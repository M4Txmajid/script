	local function scanItemNames()
		local seen, result = {}, {}
		local folder = workspace:FindFirstChild("Items")
		if not folder then return result end
		for _, child in pairs(folder:GetChildren()) do
			if not seen[child.Name] then
				seen[child.Name] = true
				table.insert(result, child.Name)
			end
		end
		table.sort(result)
		return result
	end

	local function scanMapLocations()
		local locations = {}
		local mapFolder = game:GetService("ReplicatedStorage"):FindFirstChild("Map")
		if not mapFolder then return locations end
		for _, folder in pairs(mapFolder:GetChildren()) do
			if folder:IsA("Folder") or folder:IsA("Configuration") or folder:IsA("Model") then
				local x = folder:GetAttribute("X") or folder:GetAttribute("PosX") or folder:GetAttribute("PositionX")
				local y = folder:GetAttribute("Y") or folder:GetAttribute("PosY") or folder:GetAttribute("PositionY")
				local z = folder:GetAttribute("Z") or folder:GetAttribute("PosZ") or folder:GetAttribute("PositionZ")
				local posAttr = folder:GetAttribute("Position") or folder:GetAttribute("Coordinates")
				if posAttr and typeof(posAttr) == "Vector3" then
					x, y, z = posAttr.X, posAttr.Y, posAttr.Z
				end
				if x and z then
					table.insert(locations, { Name = folder.Name, Pos = Vector3.new(x, y or 0, z) })
				end
			end
		end
		table.sort(locations, function(a, b) return a.Name < b.Name end)
		return locations
	end

