	local ESP_ENABLED  = false
	local ESP_SELECTED = nil
	local espHighlights = {}

	local function scanTreeNames()
		local names = {}
		local seen  = {}
		local foliage = workspace:FindFirstChild("Map")
		foliage = foliage and foliage:FindFirstChild("Foliage")
		if foliage then
			for _, obj in pairs(foliage:GetChildren()) do
				if (obj:GetAttribute("Interaction") == "Resource" or obj:GetAttribute("Resource") ~= nil)
					and not seen[obj.Name] then
					seen[obj.Name] = true
					table.insert(names, obj.Name)
				end
			end
		end
		table.sort(names)
		table.insert(names, 1, "All Trees")
		return names
	end

	local function applyESPHighlight(tree)
		if not tree or not tree.Parent then return end
		local hp    = tree:GetAttribute("Health") or 0
		local maxHp = tree:GetAttribute("MaxHealth") or hp
		local ratio = maxHp > 0 and math.clamp(hp / maxHp, 0, 1) or 1
		local r = math.floor((1 - ratio) * 255)
		local g = math.floor(ratio * 200)
		local barCol = Color3.fromRGB(r, g, 0)
		local adorn = tree.PrimaryPart or tree:FindFirstChildWhichIsA("BasePart", true)
		if not adorn then return end
		local bb = espHighlights[tree]
		if not bb or not bb.Parent then
			bb = Instance.new("BillboardGui")
			bb.Name         = "TreeESP"
			bb.Size         = UDim2.new(0, 80, 0, 36)
			bb.StudsOffset  = Vector3.new(0, 6, 0)
			bb.AlwaysOnTop  = true
			bb.ResetOnSpawn = false
			bb.Adornee      = adorn
			bb.Parent       = adorn
			local lbl = Instance.new("TextLabel")
			lbl.Name               = "HPLabel"
			lbl.Size               = UDim2.new(1, 0, 0, 16)
			lbl.BackgroundTransparency = 1
			lbl.TextColor3         = Color3.fromRGB(255, 255, 255)
			lbl.Font               = Enum.Font.GothamBold
			lbl.TextSize           = 13
			lbl.Text               = ""
			lbl.Parent             = bb
			local barBG = Instance.new("Frame")
			barBG.Name             = "BarBG"
			barBG.Size             = UDim2.new(1, 0, 0, 8)
			barBG.Position         = UDim2.new(0, 0, 0, 18)
			barBG.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
			barBG.BorderSizePixel  = 0
			barBG.Parent           = bb
			Instance.new("UICorner", barBG).CornerRadius = UDim.new(0, 3)
			local barFill = Instance.new("Frame")
			barFill.Name             = "BarFill"
			barFill.Size             = UDim2.new(1, 0, 1, 0)
			barFill.BackgroundColor3 = barCol
			barFill.BorderSizePixel  = 0
			barFill.Parent           = barBG
			Instance.new("UICorner", barFill).CornerRadius = UDim.new(0, 3)
			espHighlights[tree] = bb
		else
			bb.Adornee = adorn
		end
		local lbl2    = bb:FindFirstChild("HPLabel")
		local barFill2 = bb:FindFirstChild("BarBG") and bb.BarBG:FindFirstChild("BarFill")
		if lbl2     then lbl2.Text = math.floor(hp) .. " / " .. math.floor(maxHp) end
		if barFill2 then
			barFill2.Size             = UDim2.new(ratio, 0, 1, 0)
			barFill2.BackgroundColor3 = barCol
		end
	end

	local function clearAllESP()
		for _, hl in pairs(espHighlights) do
			if hl then hl:Destroy() end
		end
		espHighlights = {}
	end

	-- ESP refresh loop
	task.spawn(function()
		while true do
			task.wait(0.5)
			if not ESP_ENABLED then continue end
			local foliage = workspace:FindFirstChild("Map")
			foliage = foliage and foliage:FindFirstChild("Foliage")
			if not foliage then continue end
			for tree, hl in pairs(espHighlights) do
				if not tree or not tree.Parent or (tree:GetAttribute("Health") or 0) <= 0 then
					if hl then hl:Destroy() end
					espHighlights[tree] = nil
				end
			end
			for _, tree in pairs(foliage:GetChildren()) do
				local isRes = tree:GetAttribute("Interaction") == "Resource" or tree:GetAttribute("Resource") ~= nil
				if not isRes then continue end
				if (tree:GetAttribute("Health") or 0) <= 0 then continue end
				if ESP_SELECTED and ESP_SELECTED ~= "All Trees" and tree.Name ~= ESP_SELECTED then continue end
				applyESPHighlight(tree)
			end
		end
	end)

