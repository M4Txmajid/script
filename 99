local function dragToCamp(lm) local cf=getCamp() if not cf then return end local m=lm:FindFirstChild("Main") or lm:FindFirstChildWhichIsA("BasePart",true) if m then m.CFrame=CFrame.new(CAMP.POS.X+math.random(-2,2),CAMP.POS.Y+CAMP.HEIGHT,CAMP.POS.Z+math.random(-2,2))*CFrame.Angles(0,math.rad(math.random(0,360)),math.rad(90)) end pcall(function() ReqDrag:FireServer(lm) ReqBurn:FireServer(cf,lm) end) end
local function bringName(n) if not HRP or not HRP.Parent then return end local f=workspace:FindFirstChild("Items") if f then for _,c in pairs(f:GetChildren()) do if c.Name==n then local p=c:FindFirstChildWhichIsA("BasePart",true) if p then p.CFrame=HRP.CFrame*CFrame.new(math.random(-4,4),15,math.random(-4,4)) pcall(function() ReqDrag:FireServer(c) end) end end end end end

