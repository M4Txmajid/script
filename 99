-- ═══════════════════════════════════════════════════════════
-- ADVANCED UNDETECTABLE WALKSPEED SYSTEM
-- ═══════════════════════════════════════════════════════════

local WalkSpeedSettings = {
    StepIncrease = true,
    StepAmount = 2,
    StepDelay = 0.05,
    MaxDeviation = 1,
    UseBodyVelocity = true,
}

local StepRunning = false
local BodyVel = nil

local function GetHumanoid()
    if player.Character then
        local hum = player.Character:FindFirstChildOfClass("Humanoid")
        if hum and hum.Health > 0 then
            return hum
        end
    end
    return nil
end

local function GetRootPart()
    if player.Character then
        return player.Character:FindFirstChild("HumanoidRootPart")
    end
end

local function CleanBodyVelocity()
    if BodyVel then
        pcall(function() BodyVel:Destroy() end)
        BodyVel = nil
    end
end

local function SetSpeedDirect(speed)
    local hum = GetHumanoid()
    if hum and hum.Health > 0 then
        hum.WalkSpeed = speed
    end
end

local function ApplyBodyVelocity(speed)
    local root = GetRootPart()
    local hum = GetHumanoid()
    if not root or not hum or hum.Health <= 0 then return end

    CleanBodyVelocity()

    local moveDir = hum.MoveDirection
    if moveDir.Magnitude > 0 then
        BodyVel = Instance.new("BodyVelocity")
        BodyVel.Velocity = moveDir * speed
        BodyVel.MaxForce = Vector3.new(1e5, 0, 1e5)
        BodyVel.P = 1e4
        BodyVel.Parent = root
    end
end

local function StepSpeed(targetSpeed)
    if StepRunning then return end
    StepRunning = true

    task.spawn(function()
        local hum = GetHumanoid()
        if not hum then
            StepRunning = false
            return
        end

        local startSpeed = hum.WalkSpeed
        local steps = math.abs(targetSpeed - startSpeed) / WalkSpeedSettings.StepAmount

        for i = 1, steps do
            hum = GetHumanoid()
            if not hum then break end

            local deviation = math.random(
                -WalkSpeedSettings.MaxDeviation * 10,
                WalkSpeedSettings.MaxDeviation * 10
            ) / 10

            if targetSpeed > startSpeed then
                hum.WalkSpeed = math.min(
                    startSpeed + (WalkSpeedSettings.StepAmount * i) + deviation,
                    targetSpeed
                )
            else
                hum.WalkSpeed = math.max(
                    startSpeed - (WalkSpeedSettings.StepAmount * i) + deviation,
                    targetSpeed
                )
            end

            task.wait(WalkSpeedSettings.StepDelay)
        end

        hum = GetHumanoid()
        if hum then
            hum.WalkSpeed = targetSpeed
        end

        StepRunning = false
    end)
end

local function EvadeAntiCheat()
    local hum = GetHumanoid()
    if not hum or hum.Health <= 0 then return end
    if not WalkSpeedEnabled then return end

    local noise = math.random(-2, 2) / 10
    hum.WalkSpeed = WalkSpeedValue + noise
end

-- ═══════════════════════════════════════════════════════════
-- FLY FUNCTIONS
-- ═══════════════════════════════════════════════════════════

local function CreateFlyParts()
    local root = GetRootPart()
    if not root then return end

    if FlyBodyVel then pcall(function() FlyBodyVel:Destroy() end) end
    if FlyBodyGyro then pcall(function() FlyBodyGyro:Destroy() end) end

    FlyBodyVel = Instance.new("BodyVelocity")
    FlyBodyVel.Velocity = Vector3.zero
    FlyBodyVel.MaxForce = Vector3.new(1e5, 1e5, 1e5)
    FlyBodyVel.P = 1e4
    FlyBodyVel.Parent = root

    FlyBodyGyro = Instance.new("BodyGyro")
    FlyBodyGyro.MaxTorque = Vector3.new(1e5, 1e5, 1e5)
    FlyBodyGyro.P = 1e4
    FlyBodyGyro.D = 100
    FlyBodyGyro.CFrame = root.CFrame
    FlyBodyGyro.Parent = root
end

local function RemoveFlyParts()
    pcall(function()
        if FlyBodyVel then FlyBodyVel:Destroy() end
        if FlyBodyGyro then FlyBodyGyro:Destroy() end
    end)
    FlyBodyVel = nil
    FlyBodyGyro = nil
end

local function GetFlyDirection()
    local root = GetRootPart()
    if not root then return Vector3.zero end

    local camCF = Camera.CFrame
    local moveDir = Vector3.zero

    if UserInputService:IsKeyDown(Enum.KeyCode.W) then
        moveDir = moveDir + camCF.LookVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.S) then
        moveDir = moveDir - camCF.LookVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.A) then
        moveDir = moveDir - camCF.RightVector
    end
    if UserInputService:IsKeyDown(Enum.KeyCode.D) then
        moveDir = moveDir + camCF.RightVector
    end

    if FlyState.GoingUp then
        moveDir = moveDir + Vector3.new(0, 1, 0)
    end
    if FlyState.GoingDown then
        moveDir = moveDir - Vector3.new(0, 1, 0)
    end

    if moveDir.Magnitude > 0 then
        moveDir = moveDir.Unit
    end

    return moveDir
end

local function LerpFly(a, b, t)
    return a + (b - a) * t
end

local function EnableFly()
    local hum = GetHumanoid()
    local root = GetRootPart()
    if not hum or not root then return end

    FlyState.FlyEnabled = true
    FlyState.Flying = true
    FlyState.CurrentSpeed = 0

    hum.PlatformStand = true
    CreateFlyParts()
end

local function DisableFly()
    local hum = GetHumanoid()

    FlyState.FlyEnabled = false
    FlyState.Flying = false
    FlyState.CurrentSpeed = 0

    RemoveFlyParts()

    if hum then
        hum.PlatformStand = false
        local root = GetRootPart()
        if root then
            local bv = Instance.new("BodyVelocity")
            bv.Velocity = Vector3.new(0, 5, 0)
            bv.MaxForce = Vector3.new(0, 1e4, 0)
            bv.P = 1e4
            bv.Parent = root
            game:GetService("Debris"):AddItem(bv, 0.2)
        end
    end
end

function AutoLockAimbot:InitializeFly()
    RunService.Heartbeat:Connect(function()
        if not FlyState.Flying then return end

        pcall(function()
            local root = GetRootPart()
            local hum = GetHumanoid()
            if not root or not hum then return end

            hum.PlatformStand = true

            local targetSpeed = FlyState.Boosting and FlySettings.BoostSpeed or FlySettings.FlySpeed
            local dir = GetFlyDirection()

            if dir.Magnitude > 0 then
                FlyState.CurrentSpeed = LerpFly(FlyState.CurrentSpeed, targetSpeed, FlySettings.Acceleration)
            else
                FlyState.CurrentSpeed = LerpFly(FlyState.CurrentSpeed, 0, FlySettings.Deceleration)
            end

            FlyGravityOffset = FlyGravityOffset + (0.01 * FlyGravityDir)
            if FlyGravityOffset > 0.3 then FlyGravityDir = -1 end
            if FlyGravityOffset < -0.1 then FlyGravityDir = 1 end

            local jitter = Vector3.zero
            if FlySettings.RandomJitter then
                jitter = Vector3.new(
                    math.random(-100, 100) / 100 * FlySettings.JitterAmount,
                    math.random(-100, 100) / 100 * FlySettings.JitterAmount,
                    math.random(-100, 100) / 100 * FlySettings.JitterAmount
                )
            end

            local velocity = (dir * FlyState.CurrentSpeed) + jitter
            if FlySettings.FakeGravity then
                velocity = velocity + Vector3.new(0, FlyGravityOffset, 0)
            end

            if FlySettings.AntiVoid then
                local pos = root.Position
                if pos.Y > FlySettings.MaxHeight then
                    velocity = Vector3.new(velocity.X, -5, velocity.Z)
                end
                if pos.Y < FlySettings.MinHeight and FlyState.GoingDown then
                    velocity = Vector3.new(velocity.X, 0, velocity.Z)
                end
            end

            if FlyBodyVel then
                FlyBodyVel.Velocity = velocity
            end

            if FlyBodyGyro then
                FlyBodyGyro.CFrame = CFrame.new(root.Position, root.Position + Camera.CFrame.LookVector)
            end
        end)
    end)

    player.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        FlyState.Flying = false
        FlyState.Boosting = false
        FlyState.GoingUp = false
        FlyState.GoingDown = false
        FlyState.CurrentSpeed = 0
        RemoveFlyParts()

        local hum = char:WaitForChild("Humanoid")
        hum.PlatformStand = false
        
        task.wait(0.2)
        
        -- Reapply fly if it was enabled
        if FlyState.FlyEnabled then
            EnableFly()
        end
    end)
end

function AutoLockAimbot:InitializeWalkSpeed()
    RunService.Heartbeat:Connect(function()
        pcall(function()
            local hum = GetHumanoid()
            if not hum then return end

            if WalkSpeedEnabled then
                EvadeAntiCheat()

                if WalkSpeedSettings.UseBodyVelocity then
                    ApplyBodyVelocity(WalkSpeedValue)
                end
            else
                CleanBodyVelocity()
            end
        end)
    end)

    task.spawn(function()
        while true do
            task.wait(0.15)
            pcall(function()
                local hum = GetHumanoid()
                if hum and WalkSpeedEnabled then
                    if math.abs(hum.WalkSpeed - WalkSpeedValue) > 3 then
                        hum.WalkSpeed = WalkSpeedValue
                    end
                end
            end)
        end
    end)

    task.spawn(function()
        while true do
            task.wait(0.5)
            pcall(function()
                local hum = GetHumanoid()
                if not hum or not WalkSpeedEnabled then return end

                if hum.WalkSpeed < WalkSpeedValue - 2 then
                    task.wait(0.1)
                    StepSpeed(WalkSpeedValue)
                end
            end)
        end
    end)

    player.CharacterAdded:Connect(function(char)
        task.wait(0.2)
        CleanBodyVelocity()

        local hum = char:WaitForChild("Humanoid")
        task.wait(0.1)
        
        if WalkSpeedEnabled then
            StepSpeed(WalkSpeedValue)
        else
            hum.WalkSpeed = 16
        end
    end)
end

function AutoLockAimbot:FindNearestPlayer()
    local FighterController = require(player.PlayerScripts.Controllers.FighterController)
    local localFighter = FighterController:GetFighter(player)
    local localTeamId = localFighter and localFighter:Get("TeamID") or nil
    
    local nearestData = nil
    local nearestDistance = math.huge
    
    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if otherPlayer == player or not otherPlayer.Character then
            continue
        end
        
        local otherHead = otherPlayer.Character:FindFirstChild("Head")
        if not otherHead then continue end
        
        local humanoid = otherPlayer.Character:FindFirstChild("Humanoid")
        if not humanoid or humanoid.Health <= 0 then
            continue
        end
        
        if self.TeamCheck and localTeamId then
            local otherFighter = FighterController:GetFighter(otherPlayer)
            local otherTeamId = otherFighter and otherFighter:Get("TeamID") or nil
            
            if otherTeamId and localTeamId == otherTeamId then
                continue
            end
        end
        
        local distance = (otherHead.Position - Camera.CFrame.Position).Magnitude
        if distance > self.MaxDistance then continue end
        
        local headScreenPos, onScreen = Camera:WorldToScreenPoint(otherHead.Position)
        if not onScreen then continue end
        
        local fovDistance = math.sqrt(
            (headScreenPos.X - Camera.ViewportSize.X / 2) ^ 2 +
            (headScreenPos.Y - Camera.ViewportSize.Y / 2) ^ 2
        )
        
        if fovDistance > self.FOV then continue end
        
        if distance < nearestDistance then
            nearestDistance = distance
            nearestData = {
                Player = otherPlayer,
                Head = otherHead,
                Character = otherPlayer.Character,
                Distance = distance,
                WorldDistance = distance
            }
        end
    end
    
    return nearestData
end

function AutoLockAimbot:_FindWeaponModel()
    local firstPersonFolder = Workspace:FindFirstChild("ViewModels")
    if not firstPersonFolder then return end
    
    local firstPersonModels = firstPersonFolder:FindFirstChild("FirstPerson")
    if not firstPersonModels then return end
    
    for _, model in pairs(firstPersonModels:GetChildren()) do
        if model:IsA("Model") then
            local hrp = model:FindFirstChild("HumanoidRootPart")
            if hrp then
                self.WeaponModel = model
                self.WeaponHumanoidRootPart = hrp
                self.OriginalWeaponCFrame = hrp.CFrame
                break
            end
        end
    end
end

function AutoLockAimbot:HijackCameraRotation()
    if not CameraController then
        return
    end
    
    RunService.RenderStepped:Connect(function()
        if not self.Enabled or not self.CurrentTarget then return end
        
        if not self.CurrentTarget.Character then
            self.CurrentTarget = nil
            return
        end
        
        if self.TeamCheck then
            local FighterController = require(player.PlayerScripts.Controllers.FighterController)
            local localFighter = FighterController:GetFighter(player)
            local targetFighter = FighterController:GetFighter(self.CurrentTarget)
            
            local localTeamId = localFighter and localFighter:Get("TeamID") or nil
            local targetTeamId = targetFighter and targetFighter:Get("TeamID") or nil
            
            if targetTeamId and localTeamId and localTeamId == targetTeamId then
                self.CurrentTarget = nil
                return
            end
        end
        
        local targetHead = self.CurrentTarget.Character:FindFirstChild("Head")
        if not targetHead then return end
        
        local humanoid = self.CurrentTarget.Character:FindFirstChild("Humanoid")
        if not humanoid or humanoid.Health <= 0 then
            self.CurrentTarget = nil
            return
        end
        
        local camera = Workspace.CurrentCamera
        local directionToTarget = (targetHead.Position - camera.CFrame.Position)
        
        local cframe = CFrame.new(Vector3.new(0, 0, 0), directionToTarget)
        local x, y, z = cframe:ToEulerAnglesYXZ()
        
        CameraController.Rotation = Vector2.new(x, y)
    end)
end

function AutoLockAimbot:Update()
    if not self.Enabled then return end
    
    local nearestData = self:FindNearestPlayer()
    
    if nearestData then
        self.CurrentTarget = nearestData.Player
    else
        self.CurrentTarget = nil
    end
    
    if self.WeaponFollowEnabled and self.WeaponHumanoidRootPart then
        local cameraLookVector = Camera.CFrame.LookVector
        local weaponRotation = CFrame.new(
            self.WeaponHumanoidRootPart.Position,
            self.WeaponHumanoidRootPart.Position + cameraLookVector
        )
        self.WeaponHumanoidRootPart.CFrame = weaponRotation
    end
end

function AutoLockAimbot:Initialize()
    self:_FindWeaponModel()
    self:HijackCameraRotation()
    self:InitializeWalkSpeed()
    self:InitializeFly()
    
    RunService.RenderStepped:Connect(function()
        self:Update()
    end)
end

AutoLockAimbot:Initialize()

