	local function formatCost(bp)
		local parts = {}
		if bp.WoodPrice     and bp.WoodPrice     > 0 then table.insert(parts, bp.WoodPrice     .. "W")  end
		if bp.ScrapPrice    and bp.ScrapPrice    > 0 then table.insert(parts, bp.ScrapPrice    .. "S")  end
		if bp.GemPrice      and bp.GemPrice      > 0 then table.insert(parts, bp.GemPrice      .. "G")  end
		if bp.GreenGemPrice and bp.GreenGemPrice > 0 then table.insert(parts, bp.GreenGemPrice .. "GG") end
		return #parts > 0 and table.concat(parts, " | ") or "Free"
	end

	local function getBlueprintNames()
		local names = {}
		for _, bp in ipairs(BLUEPRINTS) do
			table.insert(names, bp.Name .. " [T" .. bp.Tier .. "] (" .. formatCost(bp) .. ")")
		end
		return names
	end

	local function getBlueprintByLabel(label)
		for _, bp in ipairs(BLUEPRINTS) do
			local lbl = bp.Name .. " [T" .. bp.Tier .. "] (" .. formatCost(bp) .. ")"
			if lbl == label then return bp end
		end
		return nil
	end

	local function getHighestUnlockedTier()
		local highest = 0
		pcall(function()
			local sf = Player.PlayerGui.Interface.CraftingTable.ScrollingFrame
			for tier = 1, 5 do
				local folder = sf:FindFirstChild("Tier" .. tier)
				if folder and folder.Visible then highest = tier else break end
			end
		end)
		if highest == 0 then highest = 1 end
		return highest
	end

	local function isBlueprintUnlocked(bp)
		if not bp.Tier then return true, nil end
		local itemExists = false
		pcall(function()
			local sf     = Player.PlayerGui.Interface.CraftingTable.ScrollingFrame
			local folder = sf:FindFirstChild("Tier" .. bp.Tier)
			if folder and folder:FindFirstChild(bp.Name) then itemExists = true end
		end)
		if not itemExists then return true, nil end
		local highestTier = getHighestUnlockedTier()
		if bp.Tier > highestTier then
			return false, string.format(
				"Locked behind Tier %d. You have Tier %d. Craft a Crafting Bench %d first.",
				bp.Tier, highestTier, bp.Tier
			)
		end
		return true, nil
	end

