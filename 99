local function stopFly() flyOn=false if flyC then flyC:Disconnect() flyC=nil end if flyB then flyB:Destroy() flyB=nil end if flyG then flyG:Destroy() flyG=nil end local c=P.Character if c then local h=c:FindFirstChildOfClass("Humanoid") if h then h.PlatformStand=false end end end
local function startFly() flyOn=true local c=P.Character if not c or not HRP then return end local h=c:FindFirstChildOfClass("Humanoid") if h then h.PlatformStand=true end flyB=Instance.new("BodyVelocity") flyB.MaxForce,flyB.Velocity,flyB.Parent=Vector3.new(1e9,1e9,1e9),Vector3.zero,HRP flyG=Instance.new("BodyGyro") flyG.MaxTorque,flyG.P,flyG.Parent=Vector3.new(1e9,1e9,1e9),9e4,HRP flyC=RunService.RenderStepped:Connect(function() if not flyOn or not HRP then stopFly() return end local c2,h2=P.Character,nil if c2 then h2=c2:FindFirstChildOfClass("Humanoid") end if not h2 then return end local cf,md=workspace.CurrentCamera.CFrame,h2.MoveDirection if md.Magnitude>0 then local cL,cR=Vector3.new(cf.LookVector.X,0,cf.LookVector.Z).Unit,Vector3.new(cf.RightVector.X,0,cf.RightVector.Z).Unit local v=cf.LookVector*md:Dot(cL)+cf.RightVector*md:Dot(cR) flyB.Velocity=v.Magnitude>0 and v.Unit*FLY_SPD or Vector3.zero else flyB.Velocity=Vector3.zero end flyG.CFrame=cf end) end
