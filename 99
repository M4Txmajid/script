	local CraftTab = Window:AddTab({ Title = "Craft", Icon = "hammer" })

	local SELECTED_CRAFT = nil
	local AUTO_CRAFT     = false
	local AUTO_GRIND     = false
	local GRIND_ITEM     = nil

	CraftTab:AddParagraph({ Title = "Crafting", Content = "Select a blueprint and craft it instantly." })

	CraftTab:AddDropdown("CraftDropdown", {
		Title    = "Select Blueprint",
		Values   = getBlueprintNames(),
		Default  = nil,
		Callback = function(v)
			SELECTED_CRAFT = getBlueprintByLabel(v)
		end,
	})

	local function tryCraft()
		if not SELECTED_CRAFT then
			ShowNotif("No Blueprint", "Select a blueprint first.", "warn")
			return
		end
		local tierOk, tierReason = isBlueprintUnlocked(SELECTED_CRAFT)
		if not tierOk then
			ShowNotif("Tier Locked", tierReason, "warn")
			return
		end
		local success, result = false, nil
		pcall(function()
			result  = CraftItemRemote:InvokeServer(SELECTED_CRAFT.Name)
			success = result == true
		end)
		if success then
			ShowNotif("Crafting Started", SELECTED_CRAFT.Name .. " is being crafted.", "success")
		else
			ShowNotif("Craft Failed", "Could not craft " .. SELECTED_CRAFT.Name .. ". Ensure you are near a Crafting Bench.", "error")
		end
	end

	CraftTab:AddButton({
		Title       = "Craft",
		Description = "Craft the selected blueprint",
		Callback    = tryCraft,
	})

	local autoCraftGen = 0
	CraftTab:AddToggle("AutoCraftToggle", {
		Title    = "Auto Craft (every 3s)",
		Default  = false,
		Callback = function(v)
			AUTO_CRAFT = v
			if v then
				autoCraftGen = autoCraftGen + 1
				local myGen = autoCraftGen
				ShowNotif("Auto Craft", "Auto Craft ON", "success")
				task.spawn(function()
					while AUTO_CRAFT and autoCraftGen == myGen do
						pcall(tryCraft)
						task.wait(3)
					end
				end)
			else
				ShowNotif("Auto Craft", "Auto Craft OFF", "warn")
			end
		end,
	})

	-- Grinder section
	CraftTab:AddParagraph({ Title = "Grinder", Content = "Send items to the scrapper to get scrap." })

	CraftTab:AddDropdown("GrindDropdown", {
		Title    = "Select Item to Grind",
		Values   = getGrindableNames(),
		Default  = nil,
		Callback = function(v)
			GRIND_ITEM = v
		end,
	})

	local function doGrindItem()
		if not GRIND_ITEM then return 0 end
		local folder = workspace:FindFirstChild("Items")
		if not folder then return 0 end
		local done = 0
		for _, child in pairs(folder:GetChildren()) do
			if child.Name == GRIND_ITEM then
				local part = child.PrimaryPart or child:FindFirstChildWhichIsA("BasePart", true)
				if part then
					part.CFrame = SCRAPPER_CFRAME * CFrame.new(
						math.random(-1,1)*0.3, 1.5, math.random(-1,1)*0.3
					)
					pcall(function() RequestStartDragging:FireServer(child) end)
					done += 1
				end
			end
		end
		return done
	end

	CraftTab:AddButton({
		Title       = "Grind Selected",
		Description = "Send selected item to the scrapper",
		Callback    = function()
			if not GRIND_ITEM then ShowNotif("Grinder", "Select an item first!", "warn") return end
			local count = doGrindItem()
			if count > 0 then
				ShowNotif("Grinder", "Sent " .. count .. " " .. GRIND_ITEM .. " to grinder!", "success")
			else
				ShowNotif("Grinder", "No " .. GRIND_ITEM .. " found!", "warn")
			end
		end,
	})

	CraftTab:AddButton({
		Title       = "Grind All",
		Description = "Send all grindable items to the scrapper",
		Callback    = function()
			local folder = workspace:FindFirstChild("Items")
			if not folder then ShowNotif("Grind All", "No Items folder found!", "error") return end
			local done = 0
			for _, child in pairs(folder:GetChildren()) do
				local scrappable = child:GetAttribute("Scrappable")
				local canGrind, isGem = false, false
				pcall(function() canGrind = child:HasTag("CanBeGrinded") end)
				pcall(function() isGem = child:HasTag("Gem") or child:HasTag("GreenGem") end)
				if scrappable or canGrind or isGem then
					local part = child.PrimaryPart or child:FindFirstChildWhichIsA("BasePart", true)
					if part then
						part.CFrame = SCRAPPER_CFRAME * CFrame.new(
							math.random(-1,1)*0.3, 1.5, math.random(-1,1)*0.3
						)
						pcall(function() RequestStartDragging:FireServer(child) end)
						done += 1
					end
				end
			end
			ShowNotif("Grind All", done > 0 and "Sent " .. done .. " item(s) to grinder!" or "No grindable items found!", done > 0 and "success" or "warn")
		end,
	})

	local autoGrindGen = 0
	CraftTab:AddToggle("AutoGrindToggle", {
		Title    = "Auto Grind (every 2s)",
		Default  = false,
		Callback = function(v)
			AUTO_GRIND = v
