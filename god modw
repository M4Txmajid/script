    local StatusFrame = Instance.new("Frame")
    StatusFrame.Name = "StatusFrame"
    StatusFrame.Size = UDim2.new(1, 0, 0, 30)
    StatusFrame.BackgroundColor3 = Color3.fromRGB(40, 40, 55)
    StatusFrame.BorderSizePixel = 0
    StatusFrame.Parent = Content
    
    local StatusCorner = Instance.new("UICorner")
    StatusCorner.CornerRadius = UDim.new(0, 8)
    StatusCorner.Parent = StatusFrame
    
    local StatusDot = Instance.new("Frame")
    StatusDot.Name = "StatusDot"
    StatusDot.Size = UDim2.new(0, 12, 0, 12)
    StatusDot.Position = UDim2.new(0, 10, 0.5, -6)
    StatusDot.BackgroundColor3 = Color3.fromRGB(255, 80, 80)
    StatusDot.BorderSizePixel = 0
    StatusDot.Parent = StatusFrame
    
    local DotCorner = Instance.new("UICorner")
    DotCorner.CornerRadius = UDim.new(1, 0)
    DotCorner.Parent = StatusDot
    
    local StatusText = Instance.new("TextLabel")
    StatusText.Name = "StatusText"
    StatusText.Size = UDim2.new(1, -35, 1, 0)
    StatusText.Position = UDim2.new(0, 30, 0, 0)
    StatusText.BackgroundTransparency = 1
    StatusText.Text = "DISABLED"
    StatusText.TextColor3 = Color3.fromRGB(200, 200, 200)
    StatusText.TextSize = 14
    StatusText.Font = Enum.Font.GothamSemibold
    StatusText.TextXAlignment = Enum.TextXAlignment.Left
    StatusText.Parent = StatusFrame
    
    local ToggleBtn = Instance.new("TextButton")
    ToggleBtn.Name = "ToggleBtn"
    ToggleBtn.Size = UDim2.new(1, 0, 0, 45)
    ToggleBtn.Position = UDim2.new(0, 0, 0, 40)
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 180, 0)
    ToggleBtn.Text = "⚡ ACTIVATE"
    ToggleBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
    ToggleBtn.TextSize = 14
    ToggleBtn.Font = Enum.Font.GothamBold
    ToggleBtn.Parent = Content
    
    local ToggleCorner = Instance.new("UICorner")
    ToggleCorner.CornerRadius = UDim.new(0, 10)
    ToggleCorner.Parent = ToggleBtn
    
    -- Dragging
    local dragging = false
    local dragStart = nil
    local startPos = nil
    
    TitleBar.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = MainFrame.Position
        end
    end)
    
    TitleBar.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or 
           input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or 
                         input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            MainFrame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
    
    -- Minimize
    local minimized = false
    
    MinimizeBtn.MouseButton1Click:Connect(function()
        minimized = not minimized
        local targetSize = minimized and UDim2.new(0, 180, 0, 35) or UDim2.new(0, 180, 0, 130)
        local tween = TweenService:Create(MainFrame, TweenInfo.new(0.3, Enum.EasingStyle.Quart), {Size = targetSize})
        tween:Play()
        Content.Visible = not minimized
        MinimizeBtn.Text = minimized and "+" or "−"
    end)
    
    return {
        ScreenGui = ScreenGui,
        ToggleBtn = ToggleBtn,
        StatusDot = StatusDot,
        StatusText = StatusText
    }
end

local guiElements = createGui()

-- ══════════════════════════
--     GUI UPDATE FUNCTION
-- ══════════════════════════
local function updateGuiStatus()
    if not guiElements or not guiElements.StatusDot then return end
    
    local dotColor = enabled and Color3.fromRGB(80, 255, 80) or Color3.fromRGB(255, 80, 80)
    local statusText = enabled and "ACTIVE" or "DISABLED"
    local toggleColor = enabled and Color3.fromRGB(255, 80, 80) or Color3.fromRGB(255, 180, 0)
    local toggleText = enabled and "❌ DEACTIVATE" or "⚡ ACTIVATE"
    
    TweenService:Create(guiElements.StatusDot, TweenInfo.new(0.2), {BackgroundColor3 = dotColor}):Play()
    TweenService:Create(guiElements.ToggleBtn, TweenInfo.new(0.2), {BackgroundColor3 = toggleColor}):Play()
    
    guiElements.StatusText.Text = statusText
    guiElements.ToggleBtn.Text = toggleText
end

-- ══════════════════════════
--     INFINITE JUMP INPUT
-- ══════════════════════════
UserInputService.JumpRequest:Connect(function()
    if not hum or not hum.Parent then return end

    if enabled then
        -- Infinite jump: always allow jumping, reset velocity upward
        fakeJumpVelocity = FAKE_JUMP_POWER
    else
        hum:ChangeState(Enum.HumanoidStateType.Jumping)
    end
end)

-- ══════════════════════════
--     DISABLE / ENABLE REAL JUMPING
-- ══════════════════════════
local function disableJump()
    if not hum or not hum.Parent then return end
    savedJumpPower = hum.JumpPower
    savedJumpHeight = hum.JumpHeight
    hum.JumpPower = 0
    hum.JumpHeight = 0
    hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, false)
    hum:SetStateEnabled(Enum.HumanoidStateType.Freefall, false)
end

local function restoreJump()
    if not hum or not hum.Parent then return end
    hum.JumpPower = savedJumpPower
    hum.JumpHeight = savedJumpHeight
    hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
    hum:SetStateEnabled(Enum.HumanoidStateType.Freefall, true)
end

-- ══════════════════════════
--     KILL VERTICAL VELOCITY
-- ══════════════════════════
local function killVerticalVelocity()
    if not root or not root.Parent then return end
    local vel = root.AssemblyLinearVelocity
    root.AssemblyLinearVelocity = Vector3.new(vel.X, 0, vel.Z)
end

-- ══════════════════════════
--     CREATE FAKE BODY
-- ══════════════════════════
local function buildFake(sourceChar)
    sourceChar.Archivable = true
    local clone = sourceChar:Clone()
    sourceChar.Archivable = false

    local h = clone:FindFirstChildOfClass("Humanoid")
    if h then h:Destroy() end

    for _, v in pairs(clone:GetDescendants()) do
        if v:IsA("BaseScript")
            or v:IsA("Sound")
            or v:IsA("Animator")
            or v:IsA("AnimationController")
            or v:IsA("Motor6D")
            or v:IsA("Weld")
            or v:IsA("WeldConstraint")
            or v:IsA("HingeConstraint")
            or v:IsA("BallSocketConstraint")
            or v:IsA("AlignPosition")
            or v:IsA("AlignOrientation")
            or v:IsA("BodyVelocity")
            or v:IsA("BodyForce")
            or v:IsA("BodyGyro")
            or v:IsA("BodyPosition")
            or v:IsA("VectorForce")
            or v:IsA("LinearVelocity")
            or v:IsA("AngularVelocity")
        then
            v:Destroy()
        end
    end

    for _, v in pairs(clone:GetDescendants()) do
        if v:IsA("BasePart") then
            v.Anchored = true
            v.CanCollide = false
            v.CanTouch = false
            v.CanQuery = false
            v.Velocity = Vector3.zero
        end
    end

    clone.Name = "GodmodeBody"
    clone.Parent = workspace
    return clone
end

local function buildPartMap(sourceChar, fakeChar)
    local map = {}
    for _, realPart in ipairs(sourceChar:GetDescendants()) do
        if realPart:IsA("BasePart") then
            local fakePart = fakeChar:FindFirstChild(realPart.Name, true)
            if fakePart and fakePart:IsA("BasePart") then
                map[realPart] = fakePart
            end
        end
    end
    return map
end

-- ══════════════════════════
--     SHOW REAL BODY
-- ══════════════════════════
local function showRealBody()
    if not char or not char.Parent then return end
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") then
            v.LocalTransparencyModifier = 0
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v.LocalTransparencyModifier = 0
        elseif v:IsA("BillboardGui") then
            v.Enabled = true
        end
    end
end

-- ══════════════════════════
--     FIX ROOT POSITION
-- ══════════════════════════
local function fixRootPosition()
    if isDown and root and root.Parent then
        root.CFrame = root.CFrame - Vector3.new(0, DEPTH, 0)
        killVerticalVelocity()
        isDown = false
    end
end

-- ══════════════════════════
--     ENABLE GODMODE
-- ══════════════════════════
local function enableGodmode()
    if not char or not char.Parent then return end
    if not root or not root.Parent then return end

    enabled = true
    isDown = false
    savedPositions = {}
    smoothY = {}
    groundY = root.CFrame.Position.Y
    fakeGroundY = groundY
    fakeJumpOffset = 0
    fakeJumpVelocity = 0

    disableJump()

    if fake and fake.Parent then
        fake:Destroy()
    end
    fake = buildFake(char)
    partMap = buildPartMap(char, fake)

    local fakeRoot = fake:FindFirstChild("HumanoidRootPart")
    if fakeRoot then
        workspace.CurrentCamera.CameraSubject = fakeRoot
    end

    updateGuiStatus()
    print("[Godmode] ON")
end

-- ══════════════════════════
--     DISABLE GODMODE
-- ══════════════════════════
local function disableGodmode()
    enabled = false

    fixRootPosition()

    if fake and fake.Parent then
        fake:Destroy()
    end
    fake = nil
    partMap = {}
    savedPositions = {}
    smoothY = {}
    groundY = nil
    fakeGroundY = 0
    fakeJumpOffset = 0
    fakeJumpVelocity = 0

    showRealBody()
    restoreJump()

    if hum and hum.Parent then
        workspace.CurrentCamera.CameraSubject = hum
    end

    updateGuiStatus()
    print("[Godmode] OFF")
end

-- ══════════════════════════
--     TOGGLE FUNCTION
-- ══════════════════════════
local function toggleGodmode()
    if enabled then
        disableGodmode()
    else
        enableGodmode()
    end
end

guiElements.ToggleBtn.MouseButton1Click:Connect(toggleGodmode)

-- ══════════════════════════
--     KEYBOARD TOGGLE
-- ══════════════════════════
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == TOGGLE_KEY then
        toggleGodmode()
    end
end)

-- ══════════════════════════
--     STEPPED: BRING UP + FREEZE Y
-- ══════════════════════════
RunService.Stepped:Connect(function()
    if not enabled then return end
    if not root or not root.Parent then return end

    if hum and hum.Parent then
        hum.JumpPower = 0
        hum.JumpHeight = 0
    end

    killVerticalVelocity()

    if isDown then
        local currentCF = root.CFrame
        local pos = currentCF.Position
        root.CFrame = currentCF - Vector3.new(0, pos.Y - groundY, 0)
        killVerticalVelocity()
        isDown = false
    end
end)

-- ══════════════════════════
--     HEARTBEAT: SAVE + PUSH DOWN + FREEZE
-- ══════════════════════════
RunService.Heartbeat:Connect(function()
    if not enabled then return end
    if not root or not root.Parent then return end
    if isDown then return end

    killVerticalVelocity()
    groundY = root.CFrame.Position.Y

    savedPositions = {}
    for realPart, _ in pairs(partMap) do
        if realPart and realPart.Parent then
            savedPositions[realPart] = realPart.CFrame
        end
    end

    local currentCF = root.CFrame
    root.CFrame = currentCF + Vector3.new(0, DEPTH, 0)
    killVerticalVelocity()
    isDown = true
end)

-- ══════════════════════════
--     RENDER: FAKE BODY + INFINITE JUMP + HIDE REAL
-- ══════════════════════════
RunService.RenderStepped:Connect(function(dt)
    if not enabled then return end
    if not char or not char.Parent then return end
    if not fake or not fake.Parent then return end

    -- ══ SIMULATE INFINITE JUMP PHYSICS ══
    if fakeJumpOffset > 0 or fakeJumpVelocity ~= 0 then
        fakeJumpVelocity = fakeJumpVelocity - FAKE_GRAVITY * dt
        fakeJumpOffset = fakeJumpOffset + fakeJumpVelocity * dt

        -- Land on ground
        if fakeJumpOffset <= 0 then
            fakeJumpOffset = 0
            fakeJumpVelocity = 0
        end
    end

    -- ══ POSITION FAKE PARTS ══
    for realPart, fakePart in pairs(partMap) do
        local saved = savedPositions[realPart]
        if saved and fakePart and fakePart.Parent then
            local pos = saved.Position
            local rot = saved - pos

            local finalY = groundY + fakeJumpOffset

            if realPart.Name ~= "HumanoidRootPart" and root and root.Parent then
                local rootSaved = savedPositions[root]
                if rootSaved then
                    local offsetY = pos.Y - rootSaved.Position.Y
                    finalY = groundY + offsetY + fakeJumpOffset
                end
            end

            fakePart.CFrame = rot + Vector3.new(pos.X, finalY, pos.Z)
            fakePart.Anchored = true
        end
    end

    -- ══ HIDE REAL BODY ══
    for _, v in pairs(char:GetDescendants()) do
        if v:IsA("BasePart") then
            v.LocalTransparencyModifier = 1
        elseif v:IsA("Decal") or v:IsA("Texture") then
            v.LocalTransparencyModifier = 1
        elseif v:IsA("BillboardGui") then
            v.Enabled = false
        end
    end
end)

-- ══════════════════════════
--     RESPAWN HANDLER
-- ══════════════════════════
player.CharacterAdded:Connect(function(newChar)
    local wasEnabled = enabled

    if fake and fake.Parent then
        fake:Destroy()
    end
    fake = nil
    partMap = {}
    isDown = false
    savedPositions = {}
    smoothY = {}
    enabled = false
    groundY = nil
    fakeGroundY = 0
    fakeJumpOffset = 0
    fakeJumpVelocity = 0

    char = newChar
    hum = char:WaitForChild("Humanoid")
    root = char:WaitForChild("HumanoidRootPart")
    task.wait(1)

    savedJumpPower = hum.JumpPower
    savedJumpHeight = hum.JumpHeight

    guiElements = createGui()
    guiElements.ToggleBtn.MouseButton1Click:Connect(toggleGodmode)

    if wasEnabled then
        enableGodmode()
    else
        updateGuiStatus()
    end
end)

print("Godmode v10 | Infinite Jump | PC: [K] | Mobile: Tap Button")
