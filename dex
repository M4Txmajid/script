-- SAFE MEMORY
-- ═══════════════════════════════════════════
local function memMB()
    local s, v = pcall(function() return math.floor(gcinfo() / 1024 * 10) / 10 end)
    if s then return v end
    s, v = pcall(function() return math.floor(Stats:GetTotalMemoryUsageMb() * 10) / 10 end)
    return s and v or 0
end

