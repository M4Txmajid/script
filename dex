-- filter logic
for name, d in pairs(filters) do
    d.Btn.MouseButton1Click:Connect(function()
        if name == "All" then
            d.On = not d.On
            for _, od in pairs(filters) do
                od.On = d.On
                tw(od.Btn, {BackgroundTransparency = d.On and 0.72 or 0.92}, 0.2)
                od.Dot.BackgroundColor3 = d.On and T.Green or T.Red
            end
        else
            d.On = not d.On
            tw(d.Btn, {BackgroundTransparency = d.On and 0.72 or 0.92}, 0.2)
            d.Dot.BackgroundColor3 = d.On and T.Green or T.Red

            local allOn = true
            for n2, d2 in pairs(filters) do
                if n2 ~= "All" and not d2.On then allOn = false; break end
            end
            filters["All"].On = allOn
            tw(filters["All"].Btn, {BackgroundTransparency = allOn and 0.72 or 0.92}, 0.2)
            filters["All"].Dot.BackgroundColor3 = allOn and T.Green or T.Red
        end
        refresh()
    end)
end

