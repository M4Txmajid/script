    c.Parent = parent
    return c
end

-- ═══════════════════════════════════════════
-- SAFE STROKE — pcall wrapper + frame fallback
-- ═══════════════════════════════════════════
local function stroke(parent, color, thickness, transparency)
    if STROKE_SUPPORTED then
        local ok, s = pcall(function()
            local st = Instance.new("UIStroke")
            st.Color        = color or T.Border
            st.Thickness    = thickness or 1
            st.Transparency = transparency or 0
            st.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
            st.Parent = parent
            return st
        end)
        if ok then return s end
    end

    -- ── FALLBACK: 4 thin border frames ──
    -- Only if transparency < 0.9 (skip nearly invisible strokes)
    if (transparency or 0) >= 0.9 then return nil end

    local col = color or T.Border
    local th  = math.max(1, (thickness or 1))
    local alpha = transparency or 0

    local function borderLine(size, pos)
        local line = Instance.new("Frame")
        line.Size               = size
        line.Position           = pos
        line.BackgroundColor3   = col
        line.BackgroundTransparency = alpha
        line.BorderSizePixel    = 0
        line.ZIndex             = (parent.ZIndex or 1) + 1
        line.Parent = parent
        return line
    end

    -- top
    borderLine(
        UDim2.new(1, 0, 0, th),
        UDim2.new(0, 0, 0, 0)
    )
    -- bottom
    borderLine(
        UDim2.new(1, 0, 0, th),
        UDim2.new(0, 0, 1, -th)
    )
    -- left
    borderLine(
        UDim2.new(0, th, 1, 0),
        UDim2.new(0, 0, 0, 0)
    )
    -- right
    borderLine(
        UDim2.new(0, th, 1, 0),
        UDim2.new(1, -th, 0, 0)
    )

    return nil
end

local function grad(parent, cs, rot)
    local g = Instance.new("UIGradient")
    g.Color    = cs
    g.Rotation = rot or 90
    g.Parent = parent
    return g
end

local function pad(parent, t, b, l, r)
    local u = Instance.new("UIPadding")
    u.PaddingTop    = UDim.new(0, t or 0)
    u.PaddingBottom = UDim.new(0, b or 0)
    u.PaddingLeft   = UDim.new(0, l or 0)
    u.PaddingRight  = UDim.new(0, r or 0)
    u.Parent = parent
    return u
end

local function tw(obj, props, dur, es, ed)
    local t = TweenService:Create(obj,
        TweenInfo.new(dur or 0.3, es or Enum.EasingStyle.Quart, ed or Enum.EasingDirection.Out),
        props)
    t:Play()
    return t
end

local function addHover(btn, normal, over, click)
    btn.MouseEnter:Connect(function()       tw(btn, {BackgroundColor3 = over}, 0.18) end)
    btn.MouseLeave:Connect(function()       tw(btn, {BackgroundColor3 = normal}, 0.18) end)
    btn.MouseButton1Down:Connect(function() tw(btn, {BackgroundColor3 = click or over}, 0.08) end)
    btn.MouseButton1Up:Connect(function()   tw(btn, {BackgroundColor3 = over}, 0.08) end)
end

local function darken(c, f)
    return Color3.fromRGB(
        math.clamp(c.R * 255 * f, 0, 255),
        math.clamp(c.G * 255 * f, 0, 255),
        math.clamp(c.B * 255 * f, 0, 255))
end

local function lighten(c, amt)
    return Color3.fromRGB(
        math.clamp(c.R * 255 + amt, 0, 255),
        math.clamp(c.G * 255 + amt, 0, 255),
        math.clamp(c.B * 255 + amt, 0, 255))
end

