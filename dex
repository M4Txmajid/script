local isOpen = false

local function openConsole()
    isOpen = true
    main.Visible = true
    main.BackgroundTransparency = 1
    main.Size = UDim2.new(0, mainW - 50, 0, mainH - 40)

    tw(main, {
        BackgroundTransparency = 0,
        Size = UDim2.new(0, mainW, 0, mainH),
    }, 0.42, Enum.EasingStyle.Back, Enum.EasingDirection.Out)

    togLabel.Text = "Hide"
    tw(togGlow, {BackgroundColor3 = T.Green}, 0.3)
    tw(togHolder, {BackgroundColor3 = Color3.fromRGB(18, 36, 24)}, 0.3)
end

local function closeConsole()
    isOpen = false
    togLabel.Text = "Console"
    tw(togGlow, {BackgroundColor3 = T.Accent}, 0.3)
    tw(togHolder, {BackgroundColor3 = T.BG2}, 0.3)

    local ct = tw(main, {
        BackgroundTransparency = 1,
        Size = UDim2.new(0, mainW - 50, 0, mainH - 40),
    }, 0.3, Enum.EasingStyle.Back, Enum.EasingDirection.In)

    ct.Completed:Connect(function()
        if not isOpen then main.Visible = false end
    end)
end

local function toggle()
    if isOpen then closeConsole() else openConsole() end
end

