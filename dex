-- SAFE CLIPBOARD
-- ═══════════════════════════════════════════
local function toClip(text)
    local ok = false
    pcall(function() if setclipboard then setclipboard(text); ok = true end end)
    if not ok then
        pcall(function() if toclipboard then toclipboard(text); ok = true end end)
    end
    if not ok then
        pcall(function()
            if Clipboard and Clipboard.set then Clipboard.set(text); ok = true end
        end)
    end
    return ok
end

