-- CONSOLE LOGIC
-- ═══════════════════════════════════════════
local logs   = {}
local logNum = 0
local MAX    = 600
local searchText = ""

local msgCfg = {
    [Enum.MessageType.MessageOutput]  = {C = T.Blue,   Ic = "●", Tp = "Info",     Tg = "INFO"},
    [Enum.MessageType.MessageInfo]    = {C = T.Blue,   Ic = "●", Tp = "Info",     Tg = "INFO"},
    [Enum.MessageType.MessageWarning] = {C = T.Yellow, Ic = "⚠", Tp = "Warnings", Tg = "WARN"},
    [Enum.MessageType.MessageError]   = {C = T.Red,    Ic = "✕", Tp = "Errors",   Tg = "ERROR"},
}

local function getTimestamp()
    local t = os.date("*t")
    return string.format("%02d:%02d:%02d", t.hour, t.min, t.sec)
end

local function isVisible(tp, msg)
    local ok = filters["All"].On or (filters[tp] and filters[tp].On)
    if ok and searchText ~= "" then
        ok = string.find(string.lower(msg), string.lower(searchText), 1, true) ~= nil
    end
    return ok
end

local function updStatus()
    local e, w, i = 0, 0, 0
    for _, l in ipairs(logs) do
        if     l.Tp == "Errors"   then e += 1
        elseif l.Tp == "Warnings" then w += 1
        else   i += 1 end
    end
    stTotal.Text = "◈ Total: " .. #logs
    bErr.Text    = "✕ " .. e
    bWarn.Text   = "⚠ " .. w
    bInfo.Text   = "● " .. i
end

local function refresh()
    for _, l in ipairs(logs) do
        if l.Fr and l.Fr.Parent then
            l.Fr.Visible = isVisible(l.Tp, l.Msg)
        end
    end
    updStatus()
end

local function addEntry(message, messageType)
    local cfg = msgCfg[messageType] or msgCfg[Enum.MessageType.MessageOutput]
    local ts  = getTimestamp()
    logNum += 1
    local ord = logNum

    -- entry frame
    local ef = Instance.new("Frame")
    ef.Name                 = "E" .. ord
    ef.Size                 = UDim2.new(1, -8, 0, 0)
    ef.AutomaticSize        = Enum.AutomaticSize.Y
    ef.BackgroundColor3     = ord % 2 == 0 and T.RowA or T.RowB
    ef.BorderSizePixel      = 0
    ef.LayoutOrder          = ord
    ef.ClipsDescendants     = true
    ef.Parent = scroll
    corner(ef, 6)

    local rowCol = ord % 2 == 0 and T.RowA or T.RowB
    ef.MouseEnter:Connect(function() tw(ef, {BackgroundColor3 = T.RowHover}, 0.12) end)
    ef.MouseLeave:Connect(function() tw(ef, {BackgroundColor3 = rowCol}, 0.12) end)

    -- left accent bar
    local ab = Instance.new("Frame")
    ab.Size              = UDim2.new(0, 3, 1, -6)
    ab.Position          = UDim2.new(0, 3, 0, 3)
    ab.BackgroundColor3  = cfg.C
    ab.BorderSizePixel   = 0
    ab.Parent = ef
    corner(ab, 2)

    -- tag badge
    local tagBg = Instance.new("Frame")
    tagBg.Size                  = UDim2.new(0, 50, 0, 18)
    tagBg.Position              = UDim2.new(0, 12, 0, 6)
    tagBg.BackgroundColor3      = cfg.C
    tagBg.BackgroundTransparency = 0.78
    tagBg.BorderSizePixel       = 0
    tagBg.Parent = ef
    corner(tagBg, 5)
    stroke(tagBg, cfg.C, 1, 0.5)

    local tagLbl = Instance.new("TextLabel")
    tagLbl.Size                  = UDim2.new(1, 0, 1, 0)
    tagLbl.BackgroundTransparency = 1
    tagLbl.Text                  = cfg.Tg
    tagLbl.TextColor3            = cfg.C
    tagLbl.Font                  = Enum.Font.GothamBold
    tagLbl.TextSize              = 9
    tagLbl.Parent = tagBg

    -- timestamp
    local tsLbl = Instance.new("TextLabel")
    tsLbl.Size                  = UDim2.new(0, 58, 0, 18)
    tsLbl.Position              = UDim2.new(0, 68, 0, 6)
    tsLbl.BackgroundTransparency = 1
    tsLbl.Text                  = ts
    tsLbl.TextColor3            = T.Tx3
    tsLbl.Font                  = Enum.Font.Code
    tsLbl.TextSize              = 10
    tsLbl.TextXAlignment        = Enum.TextXAlignment.Left
    tsLbl.Parent = ef

    -- message
    local ml = Instance.new("TextLabel")
    ml.Size                  = UDim2.new(1, -180, 0, 0)
    ml.Position              = UDim2.new(0, 132, 0, 5)
    ml.AutomaticSize         = Enum.AutomaticSize.Y
    ml.BackgroundTransparency = 1
    ml.Text                  = message
    ml.TextColor3            = cfg.C
    ml.Font                  = Enum.Font.Code
    ml.TextSize              = fontSize
    ml.TextXAlignment        = Enum.TextXAlignment.Left
    ml.TextWrapped           = true
    ml.RichText              = false
    ml.Parent = ef
    pad(ml, 0, 8, 0, 0)

    -- copy button
    local cpE = Instance.new("TextButton")
    cpE.Size                  = UDim2.new(0, 26, 0, 20)
    cpE.Position              = UDim2.new(1, -34, 0, 5)
    cpE.BackgroundColor3      = T.Surface
    cpE.BackgroundTransparency = 0.25
    cpE.Text                  = "📋"
    cpE.TextSize              = 11
    cpE.BorderSizePixel       = 0
    cpE.AutoButtonColor       = false
    cpE.Parent = ef
    corner(cpE, 5)
    addHover(cpE, T.Surface, T.Accent, T.AccentLt)

    local full = "[" .. ts .. "] [" .. cfg.Tg .. "] " .. message

    cpE.MouseButton1Click:Connect(function()
        local ok = toClip(full)
        cpE.Text = ok and "✅" or "⚠"
        tw(cpE, {BackgroundColor3 = ok and T.Green or T.Yellow}, 0.15)
        task.delay(1.2, function()
            if cpE and cpE.Parent then
                cpE.Text = "📋"
                tw(cpE, {BackgroundColor3 = T.Surface}, 0.15)
            end
        end)
    end)

    -- store entry
    local data = {Fr = ef, Msg = message, Full = full, Tp = cfg.Tp, Ts = ts, Ord = ord}
    table.insert(logs, data)

    -- purge oldest
    if #logs > MAX then
        local rm = table.remove(logs, 1)
        if rm.Fr and rm.Fr.Parent then rm.Fr:Destroy() end
    end

    ef.Visible = isVisible(cfg.Tp, message)

    -- auto-scroll
    task.defer(function()
        if scroll and scroll.Parent then
            scroll.CanvasPosition = Vector2.new(0, scroll.AbsoluteCanvasSize.Y)
        end
    end)

    updStatus()
end

